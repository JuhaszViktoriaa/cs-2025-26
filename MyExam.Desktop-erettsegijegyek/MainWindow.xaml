<Window x:Class="MyExam.Desktop_erettsegijegyek.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyExam.Desktop_erettsegijegyek"
        xmlns:viewmodel="clr-namespace:MyExam.Desktop_erettsegijegyek.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.DataContext>
        <viewmodel:ErettsegiViewModel/>
    </Window.DataContext>
    <StackPanel>
        <TextBlock Text="{Binding CountText}"/>

        <TextBlock Text="{Binding MinJegyText}"/>
        <TextBlock Text="{Binding MaxJegyText}"/>
        <TextBlock Text="{Binding AvgJegyText}"/>
        <TextBlock Text="{Binding AvgMagyarJegyText}"/>
        <TextBlock Text="{Binding Avg13CMagyarJegyText}"/>

        <TextBlock Text="{Binding Avg13BMatJegyText}"/>
        <TextBlock Text="{Binding Avg13BMaxJegyText}"/>
        <TextBlock Text="{Binding Avg13BMinJegyText}"/>
        <TextBlock Text="{Binding ToListTanulonevekText}"/>
        <TextBlock Text="{Binding AvgNagyAnnaText}"/>

        <TextBox Text="{Binding UpdatedJegy}"/>
    </StackPanel>
</Window>